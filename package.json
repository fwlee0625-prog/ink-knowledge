{
  "name": "mac-local-ocr-app",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "build:apple-vision": "zsh scripts/build_apple_vision_helper.sh",
    "build:macos-capture": "zsh scripts/build_macos_capture_helper.sh",
    "build:desktop": "pnpm run build:apple-vision && pnpm run build:macos-capture && pnpm run build",
    "release:check": "node scripts/prepare_release.mjs --check",
    "release:prepare": "node scripts/prepare_release.mjs",
    "setup": "zsh scripts/setup_dev.sh",
    "setup:paddle": "zsh scripts/setup_dev.sh --paddle",
    "tauri": "tauri dev",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:info": "tauri info"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-toggle": "^1.1.14",
    "@radix-ui/react-toggle-group": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "sass": "^1.77.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  }
}
