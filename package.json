{
  "name": "mac-local-ocr-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "build:apple-vision": "zsh scripts/build_apple_vision_helper.sh",
    "build:macos-capture": "zsh scripts/build_macos_capture_helper.sh",
    "build:desktop": "pnpm run build:apple-vision && pnpm run build:macos-capture && pnpm run build",
    "setup": "zsh scripts/setup_dev.sh",
    "setup:paddle": "zsh scripts/setup_dev.sh --paddle",
    "tauri": "tauri dev",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:info": "tauri info"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "sass": "^1.77.8",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  }
}
