{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "墨识",
  "version": "0.1.0",
  "identifier": "com.local.mac-ocr",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm run build:desktop",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "墨识",
        "label": "main",
        "visible": false,
        "skipTaskbar": true,
        "width": 1240,
        "height": 760,
        "minWidth": 1120,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/screenshots/**",
          "$APPDATA/clipboard-images/**",
          "$DOCUMENT/墨识/**",
          "$DOCUMENT/墨识 OCR/**",
          "$TEMP/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "category": "Productivity",
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "resources": [
      "../apple-vision/bin/moshi-ocr-native",
      "../apple-vision/bin/apple-vision-ocr",
      "../macos-capture/bin/moshi-capture-helper"
    ],
    "macOS": {
      "minimumSystemVersion": "14.0"
    }
  }
}
