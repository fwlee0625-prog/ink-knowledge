{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "墨识 OCR",
  "version": "0.1.0",
  "identifier": "com.local.mac-ocr",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm run build:desktop",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "墨识 OCR",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "category": "Productivity",
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "resources": [
      "../apple-vision/bin/moshi-ocr-native",
      "../apple-vision/bin/apple-vision-ocr"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
